generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rsvp {
  id         String   @id @default(cuid())
  name       String
  phone      String
  email      String?
  guestCount Int      @default(1)
  createdAt  DateTime @default(now())

  @@index([phone])
}
