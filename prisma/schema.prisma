generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Rsvp {
  id         String   @id @default(cuid())
  name       String
  phone      String
  email      String?
  guestCount Int      @default(1)
  createdAt  DateTime @default(now())

  @@index([phone])
}

model EmailQueue {
  id        String    @id @default(cuid())
  to        String
  subject   String
  html      String
  status    String    @default("PENDING") // PENDING, SENT, FAILED
  error     String?
  createdAt DateTime  @default(now())
  sentAt    DateTime?

  @@index([status])
}
