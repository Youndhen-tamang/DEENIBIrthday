# Get this from your Neon dashboard (same project you used for `gync`, or a new one)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Any long random string — used to protect the GET /api/rsvp endpoint
ADMIN_SECRET="choose-a-long-random-string"

# Added later once you're ready to send SMS (see README > "Adding Twilio SMS")
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_PHONE_NUMBER=""
